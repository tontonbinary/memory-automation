{
  "skill_name": "memory-automation",
  "version": "2.0.0",
  "type": "public",
  "description": "记忆自动化 Skill，实现会话内容的智能蒸馏与持久化存储（Agent 自蒸馏模式，无需 API Key）",
  "agent_id": "code",
  "triggers": {
    "manual": {
      "enabled": true,
      "keywords": ["记住", "记忆", "distill", "distillation", "TODO", "暂存", "搁置", "先记录", "以后再聊", "记一下", "忘了吗"],
      "case_sensitive": false
    },
    "agent_promise": {
      "enabled": true,
      "keywords": ["好，记到", "已记录到", "我会记住", "好，我记到", "已记到", "会记下来"],
      "case_sensitive": false
    },
    "heartbeat": {
      "enabled": true,
      "interval_minutes": 240
    }
  },
  "paths": {
    "l1_template": "~/.openclaw/workspaces/{agent}/workspace/memory/{date}.md",
    "state_file": "memory/heartbeat-state.json",
    "memory_rules": "~/.openclaw/memory-rules.md"
  },
  "distillation": {
    "extract_types": ["event", "decision", "preference", "emotion", "action"],
    "max_messages_per_distill": 50,
    "min_message_length": 10
  },
  "llm": {
    "enabled": false,
    "provider": "minimax",
    "model": "MiniMax-Text-01",
    "api_endpoint": "https://api.minimax.chat/v1/text/chatcompletion_v2",
    "temperature": 0.3,
    "max_tokens": 4000,
    "timeout": 60,
    "stream": false,
    "api_key": null
  },
  "fallback_to_regex": true,
  "entry_point": "memory/automation.py",
  "agent_self_distill": true
}